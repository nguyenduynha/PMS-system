generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Position {
  id            Int     @id @default(autoincrement())
  position_name String  @unique
  description   String?
  users         User[]

  @@map("positions")
}

model User {
  id          BigInt   @id @default(autoincrement())
  usercode    String   @unique @db.VarChar(50)
  fullName    String   @map("full_name") @db.VarChar(100)
  email       String   @unique @db.VarChar(100)
  password    String   @db.VarChar(255)
  phoneNumber String?  @unique @map("phone_number") @db.VarChar(20)
  avatarUrl   String?  @map("avatar_url") @db.VarChar(255)
  role        String   @db.VarChar(20)
  status      String   @db.VarChar(20)
  permissions String[] @default([])
  roleId      BigInt?  @map("role_id")
  roleRecord  Role?    @relation(fields: [roleId], references: [id])

  // Quan hệ với Position
  positionId Int?      @map("position_id")
  position   Position? @relation(fields: [positionId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Các quan hệ cũ của bạn
  bookings            Booking[]
  maintenance         MaintenanceRecord[]
  financeTransactions FinanceTransaction[]

  @@map("users")
}

model Role {
  id          BigInt   @id @default(autoincrement())
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @db.VarChar(80)
  module      String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  name        String   @db.VarChar(150)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  roleId       BigInt @map("role_id")
  permissionId String @map("permission_id") @db.VarChar(80)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ================================================================================================================ 
model RoomType {
  id            BigInt   @id @default(autoincrement())
  name          String   @db.VarChar(255)
  pricePerNight Decimal  @map("price_per_night")
  capacity      Int
  description   String?
  amenities     String[] @default([])

  // Pricing rates
  priceHourly    Decimal @default(0) @map("price_hourly")
  priceDaily     Decimal @default(0) @map("price_daily")
  priceOvernight Decimal @default(0) @map("price_overnight")

  priceHourlyWeekend    Decimal @default(0) @map("price_hourly_weekend")
  priceDailyWeekend     Decimal @default(0) @map("price_daily_weekend")
  priceOvernightWeekend Decimal @default(0) @map("price_overnight_weekend")

  priceHourlyHoliday    Decimal @default(0) @map("price_hourly_holiday")
  priceDailyHoliday     Decimal @default(0) @map("price_daily_holiday")
  priceOvernightHoliday Decimal @default(0) @map("price_overnight_holiday")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rooms Room[]

  @@map("room_types")
}

model Room {
  id            BigInt   @id @default(autoincrement())
  roomNumber    String   @unique @map("room_number") @db.VarChar(20)
  roomTypeId    BigInt   @map("room_type_id")
  floor         Int?
  status        String   @db.VarChar(30)
  note          String?
  amenities     String[] @default([])
  pricePerNight Decimal? @map("price_per_night") @db.Decimal(12, 2)
  capacity      Int?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  roomType    RoomType            @relation(fields: [roomTypeId], references: [id])
  bookings    Booking[]
  maintenance MaintenanceRecord[]

  @@map("rooms")
}

model Booking {
  id            BigInt   @id @default(autoincrement())
  userId        BigInt?  @map("user_id")
  roomId        BigInt   @map("room_id")
  customerId    BigInt?  @map("customer_id")
  customerName  String   @map("customer_name") @db.VarChar(255)
  customerPhone String   @map("customer_phone") @db.VarChar(20)
  customerEmail String?  @map("customer_email") @db.VarChar(255)
  nationality   String   @default("Việt Nam") @map("nationality") @db.VarChar(50)
  checkInDate   DateTime @map("check_in_date")
  checkOutDate  DateTime @map("check_out_date")
  totalAmount   Decimal  @default(0) @map("total_amount")
  status        String   @db.VarChar(50)
  bookingSource String   @default("WALK_IN") @map("booking_source") @db.VarChar(50)
  bookingType   String   @default("DAILY") @map("booking_type") @db.VarChar(30)
  guests        Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user            User?            @relation(fields: [userId], references: [id])
  room            Room             @relation(fields: [roomId], references: [id])
  customer        Customer?        @relation(fields: [customerId], references: [id])
  bookingServices BookingService[]
  invoice         Invoice?

  @@index([checkInDate])
  @@index([roomId, checkInDate, checkOutDate])
  @@map("bookings")
}

model Customer {
  id           BigInt   @id @default(autoincrement())
  fullName     String   @map("full_name") @db.VarChar(100)
  email        String?  @map("email") @db.VarChar(100)
  phoneNumber  String   @unique @map("phone_number") @db.VarChar(20)
  nationality  String?  @default("Việt Nam") @db.VarChar(50)
  identityCard String?  @unique @map("identity_card") @db.VarChar(50)
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  bookings Booking[]

  @@map("customers")
}

model Service {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.VarChar(100)
  price     Decimal
  unit      String?  @db.VarChar(50)
  status    String   @default("ACTIVE") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bookingServices BookingService[]

  @@map("services")
}

model BookingService {
  id          BigInt   @id @default(autoincrement())
  bookingId   BigInt   @map("booking_id")
  serviceId   BigInt   @map("service_id")
  quantity    Int      @default(1)
  price       Decimal
  totalAmount Decimal  @map("total_amount")
  createdAt   DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@map("booking_services")
}

model Invoice {
  id            BigInt   @id @default(autoincrement())
  invoiceNumber String   @unique @map("invoice_number") @db.VarChar(50)
  bookingId     BigInt   @unique @map("booking_id")
  subTotal      Decimal  @default(0) @map("sub_total")
  taxAmount     Decimal  @default(0) @map("tax_amount")
  discount      Decimal  @default(0)
  totalAmount   Decimal  @map("total_amount")
  status        String   @db.VarChar(20)
  processedBy   String?  @map("processed_by") @db.VarChar(100)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  booking  Booking   @relation(fields: [bookingId], references: [id])
  payments Payment[]

  @@map("invoices")
}

model Payment {
  id            BigInt   @id @default(autoincrement())
  invoiceId     BigInt   @map("invoice_id")
  amount        Decimal
  paymentMethod String   @map("payment_method") @db.VarChar(30)
  paidAt        DateTime @default(now()) @map("paid_at")
  note          String?

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

model MaintenanceRecord {
  id          BigInt    @id @default(autoincrement())
  roomId      BigInt    @map("room_id")
  staffId     BigInt?   @map("staff_id")
  description String?
  status      String    @db.VarChar(50)
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  repairCost  Decimal   @default(0) @map("repair_cost")
  remarks     String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  room  Room  @relation(fields: [roomId], references: [id])
  staff User? @relation(fields: [staffId], references: [id])

  @@map("maintenance_records")
}

model FinanceTransaction {
  id          BigInt   @id @default(autoincrement())
  code        String   @unique @db.VarChar(50)
  type        String   @db.VarChar(20) // "INCOME" hoặc "EXPENSE"
  category    String   @db.VarChar(100) // "Tiền phòng", "Dịch vụ", "Bảo trì", "Vật tư", "Khác", v.v.
  description String?  @db.VarChar(255)
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime @default(now())
  createdById BigInt   @map("created_by_id")
  createdBy   User     @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("finance_transactions")
}

model Holiday {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  holidayDate DateTime @unique @map("holiday_date") @db.Date
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("holidays")
}

model InventoryItem {
  id           BigInt   @id @default(autoincrement())
  name         String   @db.VarChar(255)
  sku          String?  @unique @db.VarChar(50)
  category     String   @db.VarChar(100)
  unit         String   @db.VarChar(50)
  quantity     Int      @default(0)
  minQuantity  Int      @default(0) @map("min_quantity")
  costPrice    Decimal  @default(0) @map("cost_price") @db.Decimal(12, 2)
  sellingPrice Decimal? @map("selling_price") @db.Decimal(12, 2)
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  transactions InventoryTransaction[]

  @@map("inventory_items")
}

model InventoryTransaction {
  id          BigInt   @id @default(autoincrement())
  type        String   @db.VarChar(20) // "IMPORT" or "EXPORT"
  itemId      BigInt   @map("item_id")
  quantity    Int
  price       Decimal  @db.Decimal(12, 2)
  totalAmount Decimal  @map("total_amount") @db.Decimal(12, 2)
  reason      String?  @db.VarChar(255)
  referenceId String?  @map("reference_id") @db.VarChar(100)
  date        DateTime @default(now())
  createdById BigInt?  @map("created_by_id")

  item InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("inventory_transactions")
}

model HotelProfile {
  id              Int      @id
  hotelName       String   @default("") @map("hotel_name") @db.VarChar(255)
  phone           String   @default("") @db.VarChar(30)
  email           String   @default("") @db.VarChar(255)
  website         String   @default("") @db.VarChar(255)
  address         String   @default("") @db.VarChar(500)
  country         String   @default("Việt Nam") @db.VarChar(100)
  province        String   @default("") @db.VarChar(100)
  businessType    String   @default("Khách sạn lưu trú") @map("business_type") @db.VarChar(150)
  taxCode         String   @default("") @map("tax_code") @db.VarChar(50)
  businessLicense String   @default("") @map("business_license") @db.VarChar(100)
  ownerName       String   @default("") @map("owner_name") @db.VarChar(255)
  ownerEmail      String   @default("") @map("owner_email") @db.VarChar(255)
  ownerPhone      String   @default("") @map("owner_phone") @db.VarChar(30)
  ownerIdentity   String   @default("") @map("owner_identity") @db.VarChar(50)
  logoDataUrl     String?  @map("logo_data_url") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("hotel_profiles")
}
